pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {
        string(name: 'GIT_BRANCH', defaultValue: 'main', description: 'Branche Git a deployer')
        string(name: 'BACKEND_HOST', defaultValue: 'CHANGE_ME', description: 'IP publique ou DNS de la VM backend Azure')
        string(name: 'BACKEND_USER', defaultValue: 'azureuser', description: 'Utilisateur SSH de la VM backend')
        string(name: 'REMOTE_APP_DIR', defaultValue: '/home/azureuser/projetFilRouge', description: 'Dossier du projet sur la VM backend')
        string(name: 'SSH_CREDENTIALS_ID', defaultValue: 'azure-backend-ssh-key', description: 'ID Jenkins du credential SSH pour la VM backend')
        booleanParam(name: 'RUN_SEED', defaultValue: false, description: 'Executer le seed apres migration')
    }

    environment {
        GIT_REPO_URL = 'https://github.com/Jathushanselvarajah/projetFilRouge.git'
        COMPOSE_PROJECT_NAME = 'projetfilrouge'
    }

    stages {
        stage('Validate Parameters') {
            steps {
                script {
                    if (!params.BACKEND_HOST?.trim() || params.BACKEND_HOST == 'CHANGE_ME') {
                        error('BACKEND_HOST doit contenir l IP publique ou le DNS de la VM backend Azure.')
                    }
                }
            }
        }

        stage('Checkout') {
            steps {
                git branch: params.GIT_BRANCH, url: env.GIT_REPO_URL
            }
        }

        stage('Install Backend Dependencies') {
            steps {
                dir('backend') {
                    sh 'npm ci'
                }
            }
        }

        stage('Run Backend Tests') {
            steps {
                dir('backend') {
                    sh 'npm test'
                }
            }
        }

        stage('Validate Docker Compose') {
            steps {
                sh 'docker compose --env-file .env.example config'
            }
        }

        stage('Deploy Backend On Azure VM') {
            steps {
                sshagent(credentials: [params.SSH_CREDENTIALS_ID]) {
                    sh """
                        ssh -o StrictHostKeyChecking=accept-new ${params.BACKEND_USER}@${params.BACKEND_HOST} \\
                          "GIT_REPO_URL='${env.GIT_REPO_URL}' GIT_BRANCH='${params.GIT_BRANCH}' REMOTE_APP_DIR='${params.REMOTE_APP_DIR}' RUN_SEED='${params.RUN_SEED}' COMPOSE_PROJECT_NAME='${env.COMPOSE_PROJECT_NAME}' bash -s" <<'REMOTE_SCRIPT'
                            set -euo pipefail

                            if ! command -v git >/dev/null 2>&1; then
                              echo "Git est absent sur la VM backend."
                              exit 1
                            fi

                            if ! command -v docker >/dev/null 2>&1; then
                              echo "Docker est absent sur la VM backend."
                              exit 1
                            fi

                            mkdir -p "\$(dirname "\$REMOTE_APP_DIR")"

                            if [ ! -d "\$REMOTE_APP_DIR/.git" ]; then
                              git clone "\$GIT_REPO_URL" "\$REMOTE_APP_DIR"
                            fi

                            cd "\$REMOTE_APP_DIR"
                            git checkout "\$GIT_BRANCH"
                            git pull --ff-only origin "\$GIT_BRANCH"

                            if [ ! -f .env ]; then
                              echo "Fichier .env manquant dans \$REMOTE_APP_DIR."
                              echo "Cree-le depuis .env.example avec les vrais secrets avant de redeployer."
                              exit 1
                            fi

                            docker compose --env-file .env up -d --build db backend

                            echo "Attente du demarrage MySQL..."
                            set -a
                            . ./.env
                            set +a

                            for attempt in \$(seq 1 30); do
                              if docker compose --env-file .env exec -T db mysqladmin ping -h 127.0.0.1 -u"\$MYSQL_USER" -p"\$MYSQL_PASSWORD" --silent; then
                                break
                              fi

                              if [ "\$attempt" -eq 30 ]; then
                                echo "MySQL ne repond pas apres 30 tentatives."
                                docker compose --env-file .env logs db
                                exit 1
                              fi

                              sleep 2
                            done

                            docker compose --env-file .env exec -T backend npm run migrate

                            if [ "\$RUN_SEED" = "true" ]; then
                              docker compose --env-file .env exec -T backend npm run seed
                            fi

                            curl -fsS http://127.0.0.1:3000/api >/dev/null
                            echo "Backend deploye et joignable localement sur la VM."
REMOTE_SCRIPT
                    """
                }
            }
        }

        stage('Public Smoke Test') {
            steps {
                sh "curl -fsS http://${params.BACKEND_HOST}:3000/api"
            }
        }
    }

    post {
        success {
            echo 'Pipeline backend terminee avec succes.'
        }
        failure {
            echo 'Pipeline backend en echec. Regarde le stage en rouge dans Jenkins.'
        }
    }
}
